{
  "manifest_version": 3,
  "name": "Mini Me",
  "version": "1.0",
  "description": "A tiny me that hangs out on your screen.",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "host_permissions": [
    "https://discord.com/*"
  ]
}
